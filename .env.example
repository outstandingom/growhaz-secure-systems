VITE_TIMELINE_LOGGER_ADDRESS=0x...
VITE_AUTHORIZATION_REGISTRY_ADDRESS=0x...
VITE_DOCUMENT_STATUS_TRACKER_ADDRESS=0x...
VITE_PROCESS_MANAGER_ADDRESS=0x...
# UserRegistry (new on-chain user/org store from contracts/UserRegistry.sol)
VITE_USER_REGISTRY_V2_ADDRESS=0x...
