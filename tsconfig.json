{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["hardhat.config.cjs", "scripts/**/*.ts", "test/**/*.ts"],
  "exclude": ["src", "node_modules", "dist", "supabase", "artifacts", "cache"]
}

