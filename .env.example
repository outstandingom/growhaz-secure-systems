# ─── Hardhat / deploy (do NOT commit real .env) ─────────────────────
ALCHEMY_API_KEY=your_alchemy_key
BLOCKCHAIN_PRIVATE_KEY=0xyour_deployer_private_key
ETHERSCAN_API_KEY=optional_for_verification

# ─── Deployed addresses (paste after running deploy.ts) ─────────────
