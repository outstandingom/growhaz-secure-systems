{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["hardhat.config.cjs"],
  "exclude": ["src", "node_modules", "dist", "supabase", "artifacts", "cache", "scripts", "test", "ignition", "vite.config.ts"]
}
